DATABASE_URL="postgresql://opshub:opshub@localhost:5432/opshub?schema=public"
NEXTAUTH_SECRET="replace-with-at-least-32-characters"
NEXTAUTH_URL="http://localhost:3000"

GOOGLE_APPLICATION_CREDENTIALS="./keys/service-account.json"
GOOGLE_SHEET_ID=""
GOOGLE_CALENDARS='[]'
# Google 캘린더 소스 key(feed에 노출되는 불투명 식별자)를 calId에서 HMAC으로 파생할 server secret.
# 무염 해시는 이메일형 calId를 역산당할 수 있어 사용하지 않음(적대적 리뷰). calId가 있을 때만 필요(≥16자).
# 회전하면 기존 소스 key가 바뀌어 재시드가 새 행을 만든다 — 안정적으로 유지할 것.
CALENDAR_SOURCE_KEY_SECRET=""

SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# 연차 메일 outbox drain 라우트 인증 토큰(시스템 cron이 x-drain-token 헤더로 전달)
LEAVE_MAIL_DRAIN_TOKEN=""

LIBREOFFICE_PATH=""
ANTHROPIC_API_KEY=""

# 공공데이터포털 한국천문연구원 특일정보 API 인증키(공휴일 동기화)
DATA_GO_KR_SERVICE_KEY=""

